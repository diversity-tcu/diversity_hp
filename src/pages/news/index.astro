---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const items = (await getCollection('news'))
  .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''));
---
<Base title="お知らせ | 東京都市大学 ダイバーシティ推進室">
  <article class="page-article">
    <header class="list-hero">
      <h1>お知らせ</h1>
      <p class="list-hero-sub">NEWS</p>
    </header>

    <ul class="news-list">
      {items.map((n) => (
        <li>
          <a href={`${base}news/${n.id.replace(/\.md$/, '')}/`}>
            <time>{n.data.date}</time>
            <span class="news-list-title">{n.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </article>
</Base>

<style>
  .list-hero { text-align:center; margin: 10px 0 36px; }
  .list-hero h1 { font-size:2.6em; color:var(--brand-primary,#0655B4); margin:0; letter-spacing:.06em; font-weight:700; }
  .list-hero-sub { color:#0655B4; letter-spacing:.3em; font-size:.9em; font-style:italic; font-weight:500; opacity:.75; margin:4px 0 0; }
  .list-hero-sub::after { content:""; display:block; width:60px; height:3px; margin:14px auto 0; background:linear-gradient(90deg,#e74c3c,#f39c12,#2ecc71,#3498db,#5b6ee1); border-radius:2px; }

  .news-list { list-style:none; padding:0; margin:0; background:#fff; border-radius:10px; box-shadow:0 2px 8px rgba(0,0,0,.06); overflow:hidden; }
  .news-list li + li { border-top:1px solid #eee; }
  .news-list a { display:grid; grid-template-columns:140px 1fr; gap:20px; align-items:baseline; padding:16px 22px; text-decoration:none; color:#1a2633; transition:background .15s; }
  .news-list a:hover { background:#f5f9ff; }
  .news-list time { color:#0655B4; font-weight:600; font-size:.9em; letter-spacing:.03em; }
  .news-list-title { font-size:1em; line-height:1.5; }

  @media (max-width: 780px) {
    .news-list a { grid-template-columns:1fr; gap:4px; padding:14px 16px; }
  }
</style>
