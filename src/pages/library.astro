---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/path';
import { extractTileInfo } from '../lib/extract';

type SeriesKey = 'workinlife' | 'ikubosu' | 'mado' | 'okada';
const SERIES: { key: SeriesKey; heading: string; fallbackLabel: string; idPrefix: RegExp }[] = [
  { key: 'workinlife', heading: 'ワーク・イン・ライフ', fallbackLabel: 'ワーク・イン・ライフ', idPrefix: /^workinlife/ },
  { key: 'ikubosu',    heading: 'イクボス連載企画',       fallbackLabel: 'イクボス連載企画',       idPrefix: /^ikubosu\d/ },
  { key: 'mado',       heading: 'コラム「窓」',           fallbackLabel: 'コラム「窓」',           idPrefix: /^mado\d/ },
  { key: 'okada',      heading: '岡田往子先生と女性活躍推進のあゆみ', fallbackLabel: '岡田往子先生と女性活躍推進のあゆみ', idPrefix: /^okada\d/ },
];

const FALLBACK_THUMB: Record<SeriesKey, string> = {
  workinlife: '/uploads/2025/10/workinlife01.png',
  ikubosu:    '/uploads/2022/03/ikubosu01.png',
  mado:       '/uploads/2022/03/mado01.png',
  okada:      '/uploads/2022/03/okada01.png',
};

const all = await getCollection('pages');
const bySeries: Record<SeriesKey, any[]> = { workinlife: [], ikubosu: [], mado: [], okada: [] };
for (const it of all) {
  for (const s of SERIES) {
    if (s.idPrefix.test(it.id)) {
      // Special-case "最終回" for okada6 etc.
      const title = it.data.title || '';
      const info = extractTileInfo(title, it.body);
      if (!info.vol && /最終/.test(title)) info.vol = '最終回';
      const slug = it.data.slug || it.id.replace(/\.md$/, '').split('/').pop() || '';
      bySeries[s.key].push({ it, info, slug, seriesLabel: s.fallbackLabel });
      break;
    }
  }
}
for (const k of Object.keys(bySeries) as SeriesKey[]) {
  bySeries[k].sort((a, b) => (b.it.data.date || '').localeCompare(a.it.data.date || ''));
}
// For okada: put "最終回" entry at the top (by date sort it should already be, but
// okada6 has the latest date).
---
<Base title="ライブラリ | 東京都市大学 ダイバーシティ推進室">
  <article>
    <div class="entry-content page-article">
      <h1>ライブラリ</h1>
      <p>連載ごとに分けて掲載しています。タイルをクリックすると各回の本文へ移動します。</p>
      {SERIES.map((s) => (
        bySeries[s.key].length > 0 && (
          <>
            <h2>{s.heading}</h2>
            <div class="pub-list">
              {bySeries[s.key].map(({ info, slug, seriesLabel }) => (
                <a class="pub-item" href={withBase(`/${slug}/`)}>
                  <div class="pub-item-thumb">
                    <img src={withBase(info.thumb || FALLBACK_THUMB[s.key])} alt="" loading="lazy" />
                  </div>
                  <div class="pub-item-title">
                    {info.vol && <span class="pub-item-vol">{info.vol}</span>}
                    {info.affiliation && <span class="pub-item-affiliation">{info.affiliation}</span>}
                    <span class="pub-item-name">
                      {info.name ? `${info.name}${info.role ? `　${info.role}` : ''}` : seriesLabel}
                    </span>
                  </div>
                </a>
              ))}
            </div>
          </>
        )
      ))}
    </div>
  </article>
</Base>
