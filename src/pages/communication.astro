---
import Base from '../layouts/Base.astro';
import { withBase } from '../lib/path';
import { getCollection } from 'astro:content';

const entries = (await getCollection('communication'))
  .map((e) => e.data)
  .sort((a, b) => (b.date || '').localeCompare(a.date || ''));
---
<Base title="TCUダイバーシティ通信 | 東京都市大学 ダイバーシティ推進室">
  <article>
    <div class="entry-content page-article">
      <h1>TCUダイバーシティ通信</h1>
      <p>ダイバーシティ推進室が発行しているニュースレターです。バックナンバーをPDFでご覧いただけます。</p>
      <div class="pub-list">
        {entries.map((e) => (
          <a class="pub-item" href={withBase(e.pdf)} target="_blank" rel="noopener">
            {e.thumb ? (
              <div class="pub-item-thumb"><img src={withBase(e.thumb)} alt="" /></div>
            ) : (
              <div class="pub-item-thumb pub-item-thumb--fallback"><span>PDF</span></div>
            )}
            <div class="pub-item-title">{e.title}</div>
          </a>
        ))}
      </div>
    </div>
  </article>
</Base>
