---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const news = (await getCollection('news'))
  .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''))
  .slice(0, 4);

const extractFirstImage = (body: string): string | null => {
  const m = body.match(/\/uploads\/[^\s"')]+?\.(?:jpg|jpeg|png|gif|webp)/i);
  return m ? m[0] : null;
};

const fallbackThumbs = ['/assets/top/hero1.jpg', '/assets/top/hero2.jpg', '/assets/top/hero3.jpg'];

const events = (await getCollection('events'))
  .sort((a, b) => (b.data.date || '').localeCompare(a.data.date || ''))
  .slice(0, 6)
  .map((e, i) => ({
    ...e,
    thumb: extractFirstImage(e.body || '') || fallbackThumbs[i % fallbackThumbs.length],
  }));

const quickLinks = [
  { label: 'About us', sub: 'トップページ', href: '/about/' },
  { label: 'ライブラリ', sub: '資料・リンク集', href: '/library/' },
  { label: '未設定', sub: '近日公開', href: '#' },
  { label: '貸出図書', sub: 'Book Rental', href: '/rentalbooks/' },
];
---
<Base title="東京都市大学 ダイバーシティ推進室">
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-img"><img src="/assets/top/hero1.jpg" alt="" /></div>
      <div class="hero-img"><img src="/assets/top/hero2.jpg" alt="" /></div>
      <div class="hero-img"><img src="/assets/top/hero3.jpg" alt="" /></div>
    </div>
  </section>

  <section class="quicklinks">
    {quickLinks.map((q) => (
      <a class="ql-card" href={q.href}>
        <div class="ql-icon">◆</div>
        <div class="ql-text">
          <div class="ql-label">{q.label}</div>
          <div class="ql-sub">{q.sub}</div>
        </div>
      </a>
    ))}
  </section>

  <section class="news-block">
    <div class="news-head">
      <h2 class="news-title">News</h2>
      <a class="news-all" href="/news/">お知らせ一覧 &gt;</a>
    </div>
    <ul class="news-cards">
      {news.map((n) => (
        <li class="news-card">
          <time>{n.data.date}</time>
          <a href={`/news/${n.id.replace(/\.md$/, '')}/`}>{n.data.title}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="mission">
    <h2 class="mission-title">共に学び 共に働き 共に築く</h2>
    <p class="mission-sub">〜人類の豊かさを大きく創造する未来へ〜</p>
    <div class="mission-body">
      <div class="mission-pillars">
        <div class="pillar"><span>社会連携</span></div>
        <div class="pillar"><span>基盤推進</span></div>
        <div class="pillar"><span>次世代支援</span></div>
      </div>
      <div class="mission-text">
        <p>本推進室は、多様な人々が能力を発揮できる大学・社会づくりを目指して活動しています。学生・教職員を対象とした各種支援、講演会・研修の開催、刊行物の発行などを通じて、ダイバーシティ推進を進めています。</p>
        <p>3つの柱（社会連携・基盤推進・次世代支援）を軸に、学内外と連携しながら活動しています。</p>
      </div>
    </div>
  </section>

  <section class="activities">
    <h2 class="act-title">活動報告</h2>
    <div class="act-grid">
      {events.map((e) => (
        <a class="act-card" href={`/events/${e.id.replace(/\.md$/, '')}/`}>
          <div class="act-thumb" style={`background-image:url('${e.thumb}')`}></div>
          <div class="act-meta">
            <span class="act-date">{e.data.date}</span>
            <span class="act-tag">活動報告</span>
          </div>
          <div class="act-title-text">{e.data.title}</div>
        </a>
      ))}
    </div>
    <p class="act-more"><a href="/events/">活動報告一覧 &gt;</a></p>
  </section>

  <section class="footer-banner">
    <img src="/assets/top/diver.svg" alt="タイバ" />
  </section>
</Base>

<style>
  .hero { margin: -30px -20px 40px; }
  .hero-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:4px; }
  .hero-img { aspect-ratio: 4/3; overflow:hidden; }
  .hero-img img { width:100%; height:100%; object-fit:cover; display:block; }

  .quicklinks { display:grid; grid-template-columns: repeat(4, 1fr); gap:16px; margin-bottom:50px; }
  .ql-card { display:flex; align-items:center; gap:12px; background:linear-gradient(135deg,#0a7bd9,#0655B4); color:#fff; padding:18px; border-radius:10px; text-decoration:none; box-shadow:0 2px 8px rgba(0,0,0,.08); transition:transform .15s; }
  .ql-card:hover { transform:translateY(-2px); }
  .ql-icon { font-size:28px; opacity:.8; }
  .ql-label { font-weight:bold; font-size:1.05em; }
  .ql-sub { font-size:.8em; opacity:.85; }

  .news-block { background:#f5f9ff; padding:30px; border-radius:12px; margin-bottom:50px; }
  .news-head { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:16px; }
  .news-title { color:#0655B4; font-size:1.6em; margin:0; font-style:italic; }
  .news-all { color:#0655B4; text-decoration:none; font-size:.9em; }
  .news-cards { list-style:none; padding:0; margin:0; display:grid; grid-template-columns: repeat(2, 1fr); gap:10px; }
  .news-card { background:#fff; padding:12px 16px; border-radius:6px; }
  .news-card time { display:block; color:#888; font-size:.85em; margin-bottom:4px; }
  .news-card a { color:#333; text-decoration:none; font-size:.95em; }
  .news-card a:hover { color:#0655B4; }

  .mission { text-align:center; padding:40px 0; margin-bottom:50px; }
  .mission-title { font-size:2em; color:#222; margin:0 0 8px; letter-spacing:.05em; }
  .mission-sub { color:#666; margin:0 0 30px; }
  .mission-body { display:grid; grid-template-columns: 280px 1fr; gap:40px; align-items:center; text-align:left; max-width:900px; margin:0 auto; }
  .mission-pillars { position:relative; display:flex; flex-direction:column; gap:10px; }
  .pillar { background:#0655B4; color:#fff; border-radius:50%; width:110px; height:110px; display:flex; align-items:center; justify-content:center; font-weight:bold; }
  .pillar:nth-child(1) { align-self:flex-start; }
  .pillar:nth-child(2) { align-self:center; margin-left:60px; margin-top:-30px; }
  .pillar:nth-child(3) { align-self:flex-end; margin-top:-30px; }
  .mission-text p { line-height:1.8; }

  .activities { background:#f0f4f0; padding:40px 20px; margin:0 -20px 40px; border-radius:12px; }
  .act-title { text-align:center; font-size:1.6em; color:#222; margin:0 0 30px; }
  .act-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:20px; max-width:1100px; margin:0 auto; }
  .act-card { background:#fff; border-radius:8px; overflow:hidden; text-decoration:none; color:#333; box-shadow:0 2px 6px rgba(0,0,0,.06); display:flex; flex-direction:column; transition:transform .15s; }
  .act-card:hover { transform:translateY(-3px); }
  .act-thumb { aspect-ratio:16/10; background-size:cover; background-position:center; background-color:#ccc; }
  .act-meta { padding:10px 14px 4px; font-size:.8em; color:#666; display:flex; gap:10px; align-items:center; }
  .act-tag { background:#0655B4; color:#fff; padding:2px 8px; border-radius:4px; font-size:.75em; }
  .act-title-text { padding:4px 14px 14px; font-size:.95em; font-weight:500; line-height:1.5; }
  .act-more { text-align:center; margin-top:20px; }
  .act-more a { color:#0655B4; text-decoration:none; }

  .footer-banner { text-align:center; padding:30px 0; }
  .footer-banner img { max-width:300px; height:auto; }

  @media (max-width: 780px) {
    .hero-grid { grid-template-columns: 1fr; }
    .quicklinks { grid-template-columns: repeat(2, 1fr); }
    .news-cards { grid-template-columns: 1fr; }
    .mission-body { grid-template-columns: 1fr; text-align:center; }
    .mission-pillars { flex-direction:row; justify-content:center; }
    .pillar { margin:0 !important; align-self:center !important; }
    .act-grid { grid-template-columns: 1fr; }
  }
</style>
