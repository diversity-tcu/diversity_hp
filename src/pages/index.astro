---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/path';

const base = import.meta.env.BASE_URL;

const TOPIC_META = {
  environment: { label: '環境整備' },
  reform: { label: '意識改革' },
  nextgen: { label: '次世代育成' },
} as const;

type TopicKey = keyof typeof TOPIC_META;

const compareByDateDesc = (
  a: { data: { date?: string } },
  b: { data: { date?: string } },
) => {
  const aTime = a.data.date ? Date.parse(a.data.date) : 0;
  const bTime = b.data.date ? Date.parse(b.data.date) : 0;
  return bTime - aTime;
};

const resolveTopic = (explicitTopic: TopicKey | undefined, text: string): TopicKey => {
  return explicitTopic ?? classifyTopic(text);
};

const classifyTopic = (text: string): TopicKey => {
  const normalized = text.toLowerCase();

  if (
    /女子|女の子|高校生|中学生|小学生|学生向け|進路|理系|stem|girls in control|次世代|育成|キャリア教育|ロールモデル/.test(normalized)
  ) {
    return 'nextgen';
  }

  if (
    /障がい|バリアフリー|ユニバーサルデザイン|環境整備|支援|設備|配慮|保育|介護|両立|働きやす|アクセシビ/.test(normalized)
  ) {
    return 'environment';
  }

  return 'reform';
};

const news = (await getCollection('news'))
  .sort(compareByDateDesc)
  .slice(0, 3)
  .map((n) => {
    const topic = resolveTopic(n.data.topic, `${n.data.title ?? ''}\n${n.body ?? ''}`);
    return {
      ...n,
      topic,
      topicLabel: TOPIC_META[topic].label,
    };
  });

const extractFirstImage = (body: string): string | null => {
  const m = body.match(/\/uploads\/[^\s"')]+?\.(?:jpg|jpeg|png|gif|webp)/i);
  return m ? m[0] : null;
};

const fallbackThumbs = ['/assets/top/hero1.jpg', '/assets/top/hero2.jpg', '/assets/top/hero3.jpg'];

const events = (await getCollection('events'))
  .sort(compareByDateDesc)
  .slice(0, 6)
  .map((e, i) => {
    const topic = resolveTopic(e.data.topic, `${e.data.title ?? ''}\n${e.body ?? ''}`);
    return {
      ...e,
      thumb: extractFirstImage(e.body || '') || fallbackThumbs[i % fallbackThumbs.length],
      topic,
      topicLabel: TOPIC_META[topic].label,
    };
  });

const quickLinks = [
  {
    label: 'About us', sub: 'ダイバーシティ推進室', href: '/about/', icon: '◌',
    submenu: [
      { label: 'ダイバーシティについて', href: '/about/' },
      { label: '概要', href: '/overview/' },
      { label: '学長・室長挨拶', href: '/introduction/' },
      { label: '沿革/体制', href: '/history/' },
      { label: '委員/室員の紹介', href: '/members/' },
      { label: '東京都市大学ダイバーシティ推進宣言', href: '/declaration02/' },
      { label: '10私立大学共同宣言', href: '/declaration/' },
    ],
  },
  { label: 'ライフイベント\n支援制度リーフレット', sub: '', href: '/assets/life_event.pdf', icon: '▤' },
  {
    label: 'ユニバーサル\nデザインマップ', sub: '', href: '#', icon: '⌘',
    submenu: [
      { label: '世田谷キャンパス多目的トイレマップ', href: '/assets/restroom_setagaya_map.pdf' },
      { label: '横浜キャンパス多目的トイレマップ', href: '/assets/restroom_yokohama_map.pdf' },
      { label: '世田谷キャンパスUDマップ', href: '/assets/scudmap.pdf' },
      { label: '世田谷キャンパスVRマップ', href: 'https://kengo0626.shop/', external: true },
    ],
  },
  { label: '貸出図書', sub: 'Book Rental', href: '/rentalbooks/', icon: '🕮' },
];
---
<Base title="東京都市大学 ダイバーシティ推進室">
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-img hero-img-left"><img src={withBase('/assets/top/hero2.jpg')} alt="" /></div>
      <div class="hero-img hero-img-center"><img src={withBase('/assets/top/hero3.jpg')} alt="" /></div>
      <div class="hero-img hero-img-right"><img src={withBase('/assets/top/hero1.jpg')} alt="" /></div>
    </div>
  </section>

  <section class="top-panels">
    <section class="quicklinks">
      {quickLinks.map((q) => (
        q.submenu ? (
          <div class="ql-wrap">
            {q.href && q.href !== '#' ? (
              <a class="ql-card" href={withBase(q.href)}>
                <div class="ql-icon" aria-hidden="true">{q.icon}</div>
                <div class="ql-text">
                  <div class="ql-label">{q.label}</div>
                  <div class="ql-sub">{q.sub}</div>
                </div>
                <button
                  type="button"
                  class="ql-toggle"
                  aria-label="サブメニューを開く"
                  aria-expanded="false"
                  onclick="event.preventDefault();event.stopPropagation();const w=this.closest('.ql-wrap');const o=w.classList.toggle('open');this.setAttribute('aria-expanded',o);"
                >▾</button>
              </a>
            ) : (
              <button
                type="button"
                class="ql-card ql-card-btn"
                aria-haspopup="true"
                aria-expanded="false"
                onclick="const w=this.parentElement;const o=w.classList.toggle('open');this.setAttribute('aria-expanded',o);">
                <div class="ql-icon" aria-hidden="true">{q.icon}</div>
                <div class="ql-text">
                  <div class="ql-label">{q.label}</div>
                  <div class="ql-sub">{q.sub}</div>
                </div>
              </button>
            )}
            <ul class="ql-submenu">
              {q.submenu.map((s) => (
                <li>
                  <a
                    href={s.external ? s.href : withBase(s.href)}
                    target={s.external ? '_blank' : undefined}
                    rel={s.external ? 'noopener noreferrer' : undefined}
                  >{s.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ) : (
          <a class="ql-card" href={withBase(q.href)}>
            <div class="ql-icon" aria-hidden="true">{q.icon}</div>
            <div class="ql-text">
              <div class="ql-label">{q.label}</div>
              <div class="ql-sub">{q.sub}</div>
            </div>
          </a>
        )
      ))}
    </section>

    <section class="news-block">
      <div class="news-side">
        <h2 class="news-title">News</h2>
        <a class="news-all" href={`${base}news/`}>お知らせ一覧<span class="btn-arrow" aria-hidden="true">›</span></a>
      </div>
      <ul class="news-cards">
        {news.map((n) => (
          <li class="news-card">
            <a class="news-card-link" href={`${base}news/${n.id.replace(/\.md$/, '')}/`}>
              <span class={`topic-tag topic-${n.topic}`}>{n.topicLabel}</span>
              <time>New! {n.data.date}</time>
              <span>{n.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </section>

  <section class="mission">
    <h2 class="mission-title">共に学び 共に働き 共に築く</h2>
    <p class="mission-sub">〜人類の豊かさを大きく創造する未来へ〜</p>
    <div class="mission-body">
      <div class="mission-pillars">
        <div class="pillar"><span>環境整備</span></div>
        <div class="pillar"><span>意識改革</span></div>
        <div class="pillar"><span>次世代育成</span></div>
      </div>
      <div class="mission-text">
        <p>本推進室は、多様な人々が能力を発揮できる大学・社会づくりを目指して活動しています。学生・教職員を対象とした各種支援、講演会・研修の開催、刊行物の発行などを通じて、ダイバーシティ推進を進めています。</p>
        <p>3つの柱（環境整備・意識改革・次世代育成）を軸に、学内外と連携しながら活動しています。</p>
      </div>
    </div>
  </section>

  <section class="activities">
    <h2 class="act-title">活動報告</h2>
    <div class="act-grid">
      {events.map((e) => (
        <a class="act-card" href={`${base}events/${e.id.replace(/\.md$/, '')}/`}>
          <div class="act-thumb" style={`background-image:url('${withBase(e.thumb)}')`}></div>
          <div class="act-meta">
            <span class="act-date">{e.data.date}</span>
            <span class={`act-tag topic-${e.topic}`}>{e.topicLabel}</span>
          </div>
          <div class="act-title-text">{e.data.title}</div>
        </a>
      ))}
    </div>
    <p class="act-more"><a href={`${base}events/`}>活動報告一覧 &gt;</a></p>
  </section>
</Base>

<style>
  .hero {
    margin: -30px -20px 0px;
    position: relative;
  }
  .hero::before,
  .hero::after {
    content: "";
    display: block;
    height: 7px;
    background: linear-gradient(
      90deg,
      #e74c3c 0%,
      #f39c12 16%,
      #f1c40f 32%,
      #2ecc71 48%,
      #3498db 64%,
      #5b6ee1 82%,
      #e056fd 100%
    );
  }
  /* .hero::before { margin-bottom: 4px; } */
  /* .hero::after { margin-top: 4px; } */
  .hero-grid { display:grid; grid-template-columns: minmax(0, 30fr) minmax(0, 40fr) minmax(0, 30fr); gap:4px; }
  .hero-img {
    height: 260px;
    overflow: hidden;
    position: relative;
  }
  .hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--hero-x, 50%) var(--hero-y, 50%);
    display: block;
    transform-origin: center center;
    transform: scale(var(--hero-scale, 1));
  }
  .hero-img-left {
    --hero-scale: 1.1;
    --hero-x: 110%;
    --hero-y: 50%;
  }
  .hero-img-center {
    --hero-scale: 1;
    --hero-x: 50%;
    --hero-y: 80%;
  }
  .hero-img-right {
    --hero-scale: 1;
    --hero-x: 50%;
    --hero-y: 50%;
  }

  .top-panels { margin: 0 -20px 0px; background: #f9f9f9; padding: 20px 20px; border-radius: 0px; }
  .quicklinks { display:grid; grid-template-columns: repeat(4, 1fr); gap:16px; margin-bottom:24px; }
  .ql-card { display:flex; align-items:center; gap:12px; background:linear-gradient(135deg,var(--brand-primary),var(--brand-primary)); color:#fff; padding:10px 12px; border-radius:10px; text-decoration:none; box-shadow:0 2px 8px rgba(0,0,0,.08); transition:transform .15s; min-height:64px; box-sizing:border-box; }
  .ql-card:hover { transform:translateY(-2px); }
  .ql-icon { display:flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:999px; background:rgba(255,255,255,.16); font-size:18px; font-weight:700; line-height:1; flex:0 0 auto; }
  .ql-text { min-width:0; }
  .ql-card::after {
    content:"›" !important;
    display:inline-flex !important;
    align-items:center;
    justify-content:center;
    width:22px;
    height:22px;
    margin-left:auto;
    border:1.5px solid rgba(255,255,255,.85);
    border-radius:999px;
    font-size:16px;
    line-height:1;
    transform:translateX(1px);
    flex:0 0 auto;
  }
  .ql-wrap { position:relative; display:flex; }
  .ql-wrap > .ql-card { flex:1; }
  .ql-card-btn { width:100%; font:inherit; text-align:left; border:0; cursor:pointer; }
  .ql-toggle {
    display:inline-flex; align-items:center; justify-content:center;
    width:24px; height:24px; margin-left:auto;
    padding:0; border:1.5px solid rgba(255,255,255,.85); border-radius:999px;
    background:transparent; color:#fff; font-size:12px; line-height:1; cursor:pointer;
    flex:0 0 auto;
  }
  .ql-wrap > .ql-card::after { display:none !important; }
  .ql-wrap .ql-card { cursor:pointer; }
  .ql-submenu {
    position:absolute; top:100%; left:0; right:0; z-index:20;
    margin:6px 0 0; padding:6px; list-style:none;
    background:#fff; border-radius:10px; box-shadow:0 6px 20px rgba(0,0,0,.15);
    opacity:0; visibility:hidden; transform:translateY(-4px);
    transition:opacity .15s, transform .15s, visibility .15s;
  }
  .ql-wrap:hover .ql-submenu,
  .ql-wrap:focus-within .ql-submenu,
  .ql-wrap.open .ql-submenu { opacity:1; visibility:visible; transform:translateY(0); }
  .ql-submenu li { margin:0; }
  .ql-submenu a {
    display:block; padding:10px 12px; border-radius:6px;
    color:#333; text-decoration:none; font-size:.88em; line-height:1.4;
  }
  .ql-submenu a:hover { background:var(--brand-primary); color:#fff; }
  .ql-label { font-weight:bold; font-size:0.85em; line-height:1.35; white-space:pre-line; }
  .ql-sub { font-size:.72em; opacity:.85; }

  .news-block {  display:grid; grid-template-columns: 180px 1fr; gap:0px; align-items:start; }
  .news-side { display:flex; flex-direction:column; align-items:flex-start; gap:14px; }
  .news-title { color:var(--brand-primary); background:#f9f9f9; font-size:1.9em; margin:0;border: #cfcfcf; }
  .news-all { display:inline-flex; align-items:center; justify-content:center; gap:10px; min-height:32px; padding:0 14px 0 16px; border-radius:5px; background:var(--brand-primary); color:#fff; text-decoration:none; font-size:.9em; box-shadow:0 2px 8px rgba(55,186,247,.25); transition:transform .15s, box-shadow .15s; }
  .news-all:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(55,186,247,.32); }
  .btn-arrow {
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:22px;
    height:22px;
    border:1.5px solid rgba(255,255,255,.85);
    border-radius:999px;
    font-size:16px;
    line-height:1;
    transform:translateX(1px);
    flex:0 0 auto;
  }
  .news-cards { list-style:none; padding:0; margin:0; display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:14px; }
  .news-card { background:#fff; border-radius:10px; box-shadow:0 2px 10px rgba(0,0,0,.06); overflow:hidden; }
  .news-card-link { display:flex; flex-direction:column; gap:10px; min-height:100%; padding:16px 18px; color:#333; text-decoration:none; }
  .news-card time { display:block; color:#6a92aa; font-size:.82em; font-weight:600; }
  .news-card span { font-size:.96em; font-weight:500; line-height:1.6; }
  .news-card-link:hover span:last-child { color:var(--brand-primary); }
  .topic-tag { display:inline-flex; align-items:center; justify-content:center; width:fit-content; padding:4px 10px; border-radius:999px; color:#fff; font-size:.74em; font-weight:700; letter-spacing:.02em; }
  .topic-environment { background:var(--topic-environment); }
  .topic-reform { background:var(--topic-reform); }
  .topic-nextgen { background:var(--topic-nextgen); }

  .mission { text-align:center; padding: 40px 0; margin-bottom:50px; }
  .mission-title { font-size:2em; color:var(--brand-primary); background:#fff;border: #fff; gin:0 0 8px; letter-spacing:.05em; padding: 0;margin:0;}
  .mission-sub { font-size:1.2em; color:#666; margin:0 0 30px; }
  .mission-body { display:grid; grid-template-columns: minmax(0,280px) minmax(0,1fr); gap:40px; align-items:center; text-align:left; max-width:900px; margin:0 auto; }
  .mission-pillars { position:relative; width:260px; height:230px; margin:0 auto; }
  .pillar { position:absolute; color:#fff; border-radius:50%; width:110px; height:110px; display:flex; align-items:center; justify-content:center; font-weight:bold; }
  .pillar:nth-child(1) { background:var(--topic-environment); left:0; bottom:0; }
  .pillar:nth-child(2) { background:var(--topic-reform); left:50%; top:0; transform:translateX(-50%); }
  .pillar:nth-child(3) { background:var(--topic-nextgen); right:0; bottom:0; }
  .mission-text p { line-height:1.8; }

  .activities { background:#f0f4f0; padding:20px 20px; margin:0 -20px 40px; border-radius:12px; }
  .act-title { text-align:center; font-size:2em; color:var(--brand-primary); margin:0 0 10px; border:#fff; background:#f0f4f0;}
  .act-grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:20px; max-width:1100px; margin:0 auto; }
  .act-card { background:#fff; border-radius:8px; overflow:hidden; text-decoration:none; color:#333; box-shadow:0 2px 6px rgba(0,0,0,.06); display:flex; flex-direction:column; transition:transform .15s; }
  .act-card:hover { transform:translateY(-3px); }
  .act-thumb { aspect-ratio:16/10; background-size:cover; background-position:center; background-color:#ccc; }
  .act-meta { padding:10px 14px 4px; font-size:.8em; color:#666; display:flex; gap:10px; align-items:center; }
  .act-tag { color:#fff; padding:2px 8px; border-radius:4px; font-size:.75em; }
  .act-title-text { padding:4px 14px 14px; font-size:.95em; font-weight:500; line-height:1.5; }
  .act-more { text-align:center; margin-top:20px; }
  .act-more a { display:inline-flex; align-items:center; justify-content:center; min-height:32px; padding:0 16px; border-radius:5px; background:var(--brand-primary); color:#fff; text-decoration:none; font-size:.9em; box-shadow:0 2px 8px rgba(55,186,247,.25); transition:transform .15s, box-shadow .15s; }
  .act-more a:hover { transform:translateY(-1px); box-shadow:0 4px 12px rgba(55,186,247,.32); }

  .footer-banner { text-align:center; padding:30px 0; }
  .footer-banner img { max-width:300px; height:auto; }

  @media (max-width: 780px) {
    .hero { margin: -18px -14px 0; }
    .hero-grid { grid-template-columns: 1fr; }
    .hero-img { height: 200px; }
    .top-panels { margin: 0 -14px 40px; padding: 16px 14px; }
    .quicklinks { grid-template-columns: repeat(2, 1fr); gap:12px; }
    .ql-card { padding:8px 10px; }
    .ql-label { font-size:.95em; }
    .news-block { grid-template-columns: 1fr; gap:14px; }
    .news-side { gap:12px; flex-direction:row; align-items:center; justify-content:space-between; }
    .news-title { font-size:1.5em; }
    .news-cards { grid-template-columns: repeat(2, minmax(0,1fr)); }
    .mission { padding:28px 0; margin-bottom:30px; }
    .mission-title { font-size:1.5em; }
    .mission-sub { font-size:1em; margin-bottom:20px; }
    .mission-body { grid-template-columns: 1fr; text-align:center; gap:20px; }
    .mission-pillars { width:240px; height:210px; }
    .pillar { width:100px; height:100px; font-size:.9em; }
    .activities { padding:18px 14px; margin:0 -14px 30px; }
    .act-title { font-size:1.5em; }
    .act-grid { grid-template-columns: repeat(2, minmax(0,1fr)); gap:14px; }
  }
  @media (max-width: 480px) {
    .hero-img { height: 170px; }
    .quicklinks { grid-template-columns: 1fr; }
    .ql-icon { width:34px; height:34px; font-size:18px; }
    .news-cards { grid-template-columns: 1fr; }
    .news-card-link { padding:14px 14px; }
    .act-grid { grid-template-columns: 1fr; }
    .mission-title { font-size:1.3em; }
    .mission-pillars { width:220px; height:200px; }
    .pillar { width:90px; height:90px; font-size:.82em; }
    .news-side { flex-direction:column; align-items:flex-start; }
  }
</style>
