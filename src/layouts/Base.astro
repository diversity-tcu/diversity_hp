---
export interface Props {
  title?: string;
  description?: string;
}
const { title = '東京都市大学 ダイバーシティ推進室', description = '東京都市大学 ダイバーシティ推進室' } = Astro.props;
const base = import.meta.env.BASE_URL; // ends with "/"
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="stylesheet" href={`${base}assets/wp-css/common.css`} />
  <link rel="stylesheet" href={`${base}assets/wp-css/skin.css`} />
  <link rel="stylesheet" href={`${base}assets/wp-css/style.css`} />
  <link rel="stylesheet" href={`${base}assets/wp-css/custom.v2.css`} />
</head>
<body>
  <header class="navbar siteHeader">
    <div class="container siteHeadContainer">
      <div class="siteHeader_top">
        <a class="siteHeader_tcuLink" href="https://www.tcu.ac.jp/">
          <img class="siteHeader_tcuLogo" src={`${base}assets/top/tcu_header_logo.svg`} alt="東京都市大学" />
        </a>
        <a class="siteHeader_diversityLink" href={base}>
          <img class="siteHeader_diversityLogo" src={`${base}assets/top/diversity_logo.svg`} alt="東京都市大学 ダイバーシティ推進室" />
        </a>
        <nav class="siteHeader_nav">
          <ul class="gMenu">
            <li class="menu-events"><a href={`${base}events/`}><strong>活動報告</strong></a></li>
            <li class="menu-library"><a href={`${base}library/`}><strong>コラム</strong></a></li>
            <li class="menu-support"><a href={`${base}support/`}><strong>各種支援</strong></a></li>
            <li class="menu-state"><a href={`${base}state/`}><strong>都市大の現状</strong></a>
              <ul class="sub-menu">
                <li><a href={`${base}state/stateofnumber/`}>数字で見る都市大の現状</a></li>
                <li><a href={`${base}state/enquete/`}>アンケート</a></li>
              </ul>
            </li>
            <li class="menu-publication"><a href={`${base}publication/`}><strong>刊行物</strong></a>
              <ul class="sub-menu">
                <li><a href={`${base}publication/communication/`}>TCUダイバーシティ通信</a></li>
                <li><a href={`${base}publication/calendarterms/`}>カレンダー用語集</a></li>
                <li><a href={`${base}publication/rolemodel/`}>卒業生ロールモデル集</a></li>
                <li><a href={`${base}publication/t_rolemodel/`}>教員ロールモデル集</a></li>
              </ul>
            </li>
          </ul>
        </nav>
        <a class="siteHeader_action" href="https://www.diversity.tcu.ac.jp/access/#daivbtn">
          <img class="siteHeader_diver" src={`${base}assets/top/diver.svg`} alt="ダイバ" />
        </a>
      </div>
    </div>
  </header>

  <main class="mainContent">
    <slot />
  </main>

  <footer class="siteFooter">
    <div class="siteFooter_bar" aria-hidden="true"></div>
    <div class="container">
      <div class="siteFooter_top">
        <div class="siteFooter_address">
          <p>〒158-8557<br />
            東京都世田谷区玉堤1-28-1　
            世田谷キャンパス1号館3階<br />
            TEL：03-5707-0104（代）　
            FAX：03-5707-1289<br />
            開室時間：9:00〜17:00　
            (土日・祝日・大学休業日を除く)
          </p>
        </div>
        <div class="siteFooter_brand">
          <img src={`${base}assets/top/diversity_logo.svg`} alt="東京都市大学 ダイバーシティ推進室" />
        </div>
        <div class="siteFooter_diverWrap">
          <img src={`${base}assets/top/diver.svg`} alt="ダイバ" />
        </div>
      </div>
      <div class="siteFooter_rule"></div>
      <div class="siteFooter_bottom">
        <div class="siteFooter_links">
          <div class="siteFooter_linkBlock">
            <p class="siteFooter_heading siteFooter_heading-sitemap">サイトマップ</p>
            <div class="siteFooter_panel">
              <p>
              <a href={`${base}about/`}>ダイバーシティについて</a><br />
              <a href={`${base}news/`}>お知らせ</a><br />
              <a href={`${base}events/`}>活動報告</a><br />
              <a href={`${base}library/`}>ライブラリ</a><br />
              <a href={`${base}support/`}>各種支援</a><br />
              <a href={`${base}state/`}>都市大の現状</a><br />
              <a href={`${base}rentalbooks/`}>貸出図書</a><br />
              <a href={`${base}publication/`}>刊行物</a><br />
              <a href={`${base}access/`}>アクセス</a>
              </p>
            </div>
          </div>
          <div class="siteFooter_linkBlock">
            <p class="siteFooter_heading siteFooter_heading-links">関連リンク</p>
            <div class="siteFooter_panel">
              <p>
              <a href="https://www.gender.go.jp/" target="_blank" rel="noopener">内閣府男女共同参画局</a><br />
              <a href="https://www.jst.go.jp/diversity/" target="_blank" rel="noopener">JSTダイバーシティ推進</a><br />
              <a href="https://opened.network/" target="_blank" rel="noopener">全国ダイバーシティネットワークOPENeD</a><br />
              <a href="https://www.tcu.ac.jp/" target="_blank" rel="noopener">東京都市大学</a>
              </p>
            </div>
          </div>
        </div>
        <div class="copySection">Copyright © TCU. All Rights Reserved.</div>
      </div>
    </div>
  </footer>
  <style>
    :root {
      --brand-primary: #37baf7;
      --topic-environment: #2ecc71;
      --topic-reform: #5b6ee1;
      --topic-nextgen: #e74c3c;
    }
    html { margin:0; padding:0; overflow-x:hidden !important; overflow-y:auto !important; }
    body { margin:0; padding:0; min-height:100%; overflow:visible !important; font-family: -apple-system, BlinkMacSystemFont, "Hiragino Kaku Gothic ProN", "Yu Gothic", Meiryo, sans-serif; position:static !important; }
    .vk-mobile-nav,
    .vk-mobile-nav.vk-mobile-nav-open { display:none !important; top:auto !important; height:auto !important; overflow:hidden !important; }
    .siteHeader { background:#fff; border:0; box-shadow:none; }
    .siteHeader .container { max-width:1200px; margin:0 auto; padding:0 20px; }
    .siteHeader_top { display:grid; grid-template-columns: 5% 6% 10% 1fr 50% 10%; align-items:center; column-gap:0; padding:12px 0; overflow:visible; }
    .siteHeader_tcuLink,
    .siteHeader_diversityLink,
    .siteHeader_nav,
    .siteHeader_action { display:flex; align-items:center; min-width:0; width:100%; }
    .siteHeader_tcuLink { justify-content:flex-start; }
    .siteHeader_diversityLink { justify-content:flex-start; }
    .siteHeader_nav { justify-content:center; justify-self:end; border:0; box-shadow:none; }
    .siteHeader_action { justify-content:flex-end; }
    .siteHeader_tcuLink { grid-column:1; }
    .siteHeader_diversityLink { grid-column:3; }
    .siteHeader_nav { grid-column:5; }
    .siteHeader_action { grid-column:6; }
    .siteHeader_tcuLink img,
    .siteHeader_diversityLink img,
    .siteHeader_action img { display:block; width:100%; height:auto; }
    .siteHeader_tcuLogo { max-width:100%; transform:scale(2); transform-origin:left center; }
    .siteHeader_diversityLogo { max-width:100%; }
    .siteHeader_diver { max-width:40px; width:100%; transform:scale(2); transform-origin:right center; }
    .gMenu { list-style:none; padding:0; margin:0; display:flex; flex-wrap:nowrap; justify-content:center; width:100%; background:#fff; border:1px solid #d9dee5; border-radius:12px; overflow:hidden; box-shadow:none; }
    .gMenu > li { position:relative; flex:1 1 0; min-width:0; }
    .gMenu > li + li::before { content:""; position:absolute; left:0; top:18%; width:1px; height:64%; background:#d9dee5; }
    .gMenu > li > a { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; min-height:74px; color:#444; padding:10px 8px; text-decoration:none; font-size:12px; line-height:1.3; text-align:center; }
    .gMenu > li > a::before { font-size:18px; line-height:1; color:#626a73; }
    .gMenu > li > a:hover { background:#f5f7fa; }
    .gMenu > li > a strong { font-weight:600; color:#444; }
    .gMenu > li.menu-events > a::before { content:"📢"; }
    .gMenu > li.menu-library > a::before { content:"🖉"; }
    .gMenu > li.menu-support > a::before { content:"🤝"; }
    .gMenu > li.menu-state > a::before { content:"◔"; }
    .gMenu > li.menu-publication > a::before { content:"📚"; }
    .gMenu .sub-menu { display:none; position:absolute; top:100%; left:0; background:var(--brand-primary); min-width:220px; list-style:none; padding:0; margin:0; z-index:100; }
    .gMenu > li:hover .sub-menu { display:block; }
    .gMenu .sub-menu a { display:block; color:#fff; padding:10px 14px; text-decoration:none; font-size:13px; border-top:1px solid rgba(255,255,255,0.15); }
    footer.siteFooter,
    .siteFooter { background:#fff; color:#444; margin-top:0px; overflow:visible; border:0 !important; border-top:0 !important; box-shadow:none !important; }
    .siteFooter_bar { max-width:1200px; margin:0 auto; height:7px; background:linear-gradient(90deg,#e74c3c 0%,#f39c12 16%,#f1c40f 32%,#2ecc71 48%,#3498db 64%,#5b6ee1 82%,#e056fd 100%); }
    .siteFooter a { color:#444; text-decoration:none; }
    .siteFooter a:hover { color:var(--brand-primary); }
    .siteFooter .container { max-width:1200px; margin:0 auto; padding:32px 20px 24px; }
    .siteFooter_top { display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:24px; align-items:center; }
    .siteFooter_address,
    .siteFooter_brand,
    .siteFooter_diverWrap { display:flex;  font-size: 0.85em;align-items:center; justify-content:center; text-align:center; }
    .siteFooter_address { justify-content:flex-start; text-align:left; }
    .siteFooter_address p { margin:0; line-height:1.8; }
    .siteFooter_brand img { max-width:200px; width:100%; height:auto; }
    .siteFooter_diverWrap img { max-width:130px; width:100%; height:auto; }
    .siteFooter_rule { height:1px; background:#d9dee5; margin:28px 0 24px; }
    .siteFooter_bottom { display:flex; align-items:flex-start; justify-content:space-between; gap:24px; }
    .siteFooter_links { display:flex; gap:48px; align-items:flex-start; }
    .siteFooter_linkBlock { position:relative; }
    .siteFooter_heading { margin:0 0 10px; font-weight:700; color:#444; display:flex; align-items:center; gap:8px; }
    .siteFooter_heading::before { color:#7a8693; font-size:16px; }
    .siteFooter_heading-sitemap::before { content:"▦"; }
    .siteFooter_heading-links::before { content:"↗"; }
    .siteFooter_panel { position:absolute; top:calc(100% + 8px); left:0; min-width:260px; padding:14px 16px; background:#fff; border:1px solid #d9dee5; border-radius:12px; box-shadow:0 8px 24px rgba(0,0,0,.08); opacity:0; visibility:hidden; transform:translateY(8px); transition:opacity .18s, transform .18s, visibility .18s; z-index:20; }
    .siteFooter_panel p { margin:0; line-height:1.9; }
    .siteFooter_linkBlock:hover .siteFooter_panel,
    .siteFooter_linkBlock:focus-within .siteFooter_panel { opacity:1; visibility:visible; transform:translateY(0); }
    .siteFooter .copySection { margin-left:auto; margin-top:0; padding-top:0; text-align:right; font-size:12px; color:#666; white-space:nowrap; border:0; }
    .mainContent { max-width:1200px; margin:0 auto; padding:30px 20px; }
    .mainContent img { max-width:100%; height:auto; }
    h1.entry-title { border-bottom:3px solid var(--brand-primary); padding-bottom:10px; }
    .newsList { list-style:none; padding:0; }
    .newsList li { padding:10px 0; border-bottom:1px dotted #ccc; }
    .newsList time { color:#888; margin-right:12px; font-size:0.9em; }
    @media (max-width: 780px) {
      .siteHeader_top {
        grid-template-columns: 20% 20% 1fr;
        column-gap: 8px;
        row-gap: 0;
        padding: 8px 0;
        align-items: center;
      }
      .siteHeader_tcuLink { grid-column: 1; justify-content: flex-start; }
      .siteHeader_diversityLink { grid-column: 2; justify-content: flex-start; }
      .siteHeader_nav { grid-column: 3; justify-content: flex-end; position: relative; }
      .siteHeader_action { display: none; }
      .siteHeader_tcuLogo,
      .siteHeader_diversityLogo { transform: none; max-width: 100%; width: 100%; height: auto; }

      /* ハンバーガートリガー (擬似要素) */
      .siteHeader_nav::before {
        content: "☰ メニュー";
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 8px 12px;
        background: var(--brand-primary, #0655B4);
        color: #fff;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
      }
      /* メニュー本体: 通常非表示、ホバー/フォーカスで表示 */
      .siteHeader_nav .gMenu {
        display: none;
        position: absolute;
        top: 100%;
        right: 0;
        min-width: 220px;
        background: #fff;
        box-shadow: 0 8px 24px rgba(0,0,0,.18);
        border-radius: 8px;
        flex-direction: column;
        padding: 6px 0;
        z-index: 100;
        margin-top: 6px;
      }
      .siteHeader_nav:hover .gMenu,
      .siteHeader_nav:focus-within .gMenu { display: flex; }
      .gMenu > li { width: 100%; }
      .gMenu > li > a { display: block; padding: 10px 16px; color: #1a2633; font-size: 14px; }
      .gMenu > li > a:hover { background: #f5f9ff; color: var(--brand-primary, #0655B4); }
      .gMenu .sub-menu {
        position: static;
        background: #f5f9fd;
        box-shadow: none;
        min-width: 0;
        padding: 4px 0 8px;
      }
      .gMenu .sub-menu a { padding: 8px 28px; font-size: 13px; color: #333; }
      .siteFooter .container { padding:28px 14px 20px; }
      .siteFooter_top { grid-template-columns: 1fr; gap:18px; }
      .siteFooter_address,
      .siteFooter_brand,
      .siteFooter_diverWrap { justify-content:center; text-align:center; }
      .siteFooter_bottom { flex-direction:column; gap:16px; }
      .siteFooter_links { flex-direction:column; gap:16px; }
      .siteFooter .copySection { margin-left:0; margin-top:0; padding-top:0; text-align:left; white-space:normal; border:0; }
    }
    @media (max-width: 480px) {
      .mainContent { padding:18px 14px; }
      .siteFooter .container { padding:22px 14px 18px; }
      .siteFooter_address p { font-size:.9em; line-height:1.7; }
      .siteFooter_brand img { max-width:160px; }
      .siteFooter_diverWrap img { max-width:100px; }
    }
  </style>
</body>
</html>
